# ─── Server ───────────────────────────────────────────────────────────────
PORT=5050
# Use "production" on the Droplet. In production the app fails fast if any of
# MONGODB_URI / CLIENT_ORIGIN / JWT_SECRET / ADMIN_PASSWORD are missing or default.
NODE_ENV=development
# Comma-separated list of allowed browser origins (no trailing slash).
# Local dev:  http://localhost:3000
# Production: https://dilbahararomas.com,https://www.dilbahararomas.com
CLIENT_ORIGIN=http://localhost:3000

# ─── Database (MongoDB Atlas in production) ─────────────────────────────────
# Local dev:  mongodb://127.0.0.1:27017/dilbahar_aromas
# Atlas:      mongodb+srv://<user>:<password>@<cluster>.mongodb.net/dilbahar_aromas?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/dilbahar_aromas

# ─── Auth ───────────────────────────────────────────────────────────────────
# Generate a strong secret, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Seed admin (used by `npm run seed`) ────────────────────────────────────
# CHANGE THESE before seeding in production.
ADMIN_EMAIL=admin@dilbahararomas.com
ADMIN_PASSWORD=ChangeMe123!

# ─── Observability (optional) ───────────────────────────────────────────────
OTEL_ENABLED=false
